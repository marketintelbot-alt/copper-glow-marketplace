# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.playwright-cli/

# next.js
/.next/
/out/

# production
/build

# native wrapper generated files
/android/.gradle/
/android/local.properties
/android/app/build/
/android/app/src/main/assets/public/
/android/app/src/main/assets/capacitor.config.json
/android/app/src/main/assets/capacitor.plugins.json
/ios/App/Pods/
/ios/App/App/public/
/ios/App/App/capacitor.config.json
/ios/App/App.xcworkspace/xcuserdata/
/ios/App/Podfile.lock

# misc
.DS_Store
*.pem
/prisma/dev.db
/tmp.copper-glow-schema.sql

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
